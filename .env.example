HOST=127.0.0.1
PORT=7676
# Owner password generated by `devspace init` in ~/.devspace/auth.json. Set this
# only for non-interactive or fully env-driven deployments.
# DEVSPACE_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret
# Optional OAuth tuning.
# DEVSPACE_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# DEVSPACE_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# DEVSPACE_OAUTH_SCOPES=devspace
# DEVSPACE_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1
DEVSPACE_ALLOWED_ROOTS=/home/waishnav/personal,/home/waishnav/work
# cloudflare | tailscale | external. The reusable Linux runner defaults to
# Cloudflare Tunnel; Tailscale Personal is intended only for non-commercial use.
# DEVSPACE_PROXY_MODE=cloudflare
# Use a stable HTTPS origin. DevSpace derives the inbound Host allowlist from it.
# Do not include /mcp or use a temporary *.trycloudflare.com hostname.
# DEVSPACE_PUBLIC_BASE_URL=https://your-public-host.example.com
# Advanced escape hatch. `*` disables Host header allowlist protection.
# DEVSPACE_ALLOWED_HOSTS=localhost,127.0.0.1,your-public-host.example.com
DEVSPACE_TOOL_MODE=full
# off | changes | full. Defaults to off so technical tool cards stay out of chat.
# Use changes only when one aggregate review widget is useful.
DEVSPACE_WIDGETS=off
# GPT-5.6 Sol API conversion range. GAG tool results are model input; tool
# arguments are model output. Actual full-request context size is unavailable,
# so the UI shows the short-to-long-context price range. These values do not
# represent ChatGPT subscription billing. USD/JPY is intentionally configurable.
# DEVSPACE_GPT56_INPUT_USD_PER_MTOK=5
# DEVSPACE_GPT56_OUTPUT_USD_PER_MTOK=30
# DEVSPACE_GPT56_LONG_INPUT_USD_PER_MTOK=10
# DEVSPACE_GPT56_LONG_OUTPUT_USD_PER_MTOK=45
# DEVSPACE_GPT56_LONG_CONTEXT_THRESHOLD_TOKENS=272000
# DEVSPACE_USD_JPY_RATE=160
DEVSPACE_LOG_LEVEL=info
DEVSPACE_LOG_FORMAT=json
DEVSPACE_LOG_REQUESTS=1
DEVSPACE_LOG_ASSETS=0
DEVSPACE_LOG_TOOL_CALLS=1
DEVSPACE_LOG_SHELL_COMMANDS=0
# DEVSPACE_TRUST_PROXY=1
# DEVSPACE_STATE_DIR=/home/waishnav/.local/share/devspace
# DEVSPACE_WORKTREE_ROOT=/home/waishnav/.devspace/worktrees
# Maximum parallel background jobs: 1-8, default 3.
# DEVSPACE_JOB_CONCURRENCY=3
# Optional Hermes routing defaults for browser-loop jobs. Per-job --provider and
# --model options override these values.
# DEVSPACE_BROWSER_PLANNER_PROVIDER=nvidia
# DEVSPACE_BROWSER_PLANNER_MODEL=your-provider-model-id
# DEVSPACE_AUTO_LOAD_AGENTS_MD=1
# Skills are enabled by default. Set DEVSPACE_SKILLS=0 to hide them.
# DEVSPACE_SKILLS=0
# DEVSPACE_AGENT_DIR=/home/waishnav/.codex
# DEVSPACE_SKILL_PATHS=/home/waishnav/.codex/skills,/home/waishnav/.claude/skills
