{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uniplanck.com/schemas/editorial-ir-v0.schema.json",
  "title": "Editorial IR v0",
  "description": "Renderer-neutral editorial intent for the GPT-Agent AI Video Production OS.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "sequence",
    "assets",
    "operations",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "editorial-ir.v0"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "sequence": {
      "$ref": "#/$defs/sequence"
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operation"
      }
    },
    "style_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "adapter_targets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "headless",
          "palmier-pro",
          "premiere-xml",
          "premiere-uxp",
          "resolve-xml",
          "resolve-native"
        ]
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "extensions": {
      "type": "object",
      "description": "Namespaced output from approved Special Phases.",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "seconds": {
      "type": "number",
      "minimum": 0
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sequence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "width",
        "height",
        "frame_rate",
        "audio_sample_rate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "frame_rate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["numerator", "denominator"],
          "properties": {
            "numerator": {
              "type": "integer",
              "minimum": 1
            },
            "denominator": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "audio_sample_rate": {
          "type": "integer",
          "minimum": 8000
        },
        "target_duration_seconds": {
          "$ref": "#/$defs/seconds"
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$"
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "uri", "kind", "duration_seconds", "fingerprint"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["video", "audio", "image", "graphic", "caption", "generated-request"]
        },
        "duration_seconds": {
          "$ref": "#/$defs/seconds"
        },
        "fingerprint": {
          "type": "string",
          "minLength": 8
        },
        "source_frame_rate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["numerator", "denominator"],
          "properties": {
            "numerator": {
              "type": "integer",
              "minimum": 1
            },
            "denominator": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "sourceRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_id", "source_in", "source_out"],
      "properties": {
        "asset_id": {
          "type": "string",
          "minLength": 1
        },
        "source_in": {
          "$ref": "#/$defs/seconds"
        },
        "source_out": {
          "$ref": "#/$defs/seconds"
        }
      }
    },
    "timelineRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "$ref": "#/$defs/seconds"
        },
        "end": {
          "$ref": "#/$defs/seconds"
        }
      }
    },
    "baseOperation": {
      "type": "object",
      "required": ["id", "type", "track", "rationale"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "track": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "index"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["video", "audio", "caption", "graphic"]
            },
            "index": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "timeline": {
          "$ref": "#/$defs/timelineRange"
        },
        "rationale": {
          "$ref": "#/$defs/rationale"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "fallback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy"],
          "properties": {
            "policy": {
              "type": "string",
              "enum": ["fail", "skip_with_warning", "replace", "flatten"]
            },
            "replacement_operation_id": {
              "type": "string"
            },
            "note": {
              "type": "string"
            }
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "operation": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/baseOperation" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type", "track", "rationale", "source"],
              "properties": {
                "id": true,
                "type": { "const": "select_range" },
                "track": true,
                "timeline": true,
                "rationale": true,
                "enabled": true,
                "fallback": true,
                "extensions": true,
                "source": { "$ref": "#/$defs/sourceRange" },
                "playback_rate": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "default": 1
                },
                "transform": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "position_x": { "type": "number" },
                    "position_y": { "type": "number" },
                    "scale_x": { "type": "number", "exclusiveMinimum": 0 },
                    "scale_y": { "type": "number", "exclusiveMinimum": 0 },
                    "rotation_degrees": { "type": "number" },
                    "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/baseOperation" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type", "track", "timeline", "rationale", "text", "role", "style_token"],
              "properties": {
                "id": true,
                "type": { "const": "caption" },
                "track": true,
                "timeline": true,
                "rationale": true,
                "enabled": true,
                "fallback": true,
                "extensions": true,
                "text": { "type": "string", "minLength": 1 },
                "role": {
                  "type": "string",
                  "enum": [
                    "speech",
                    "summary",
                    "speaker_id",
                    "explanation",
                    "reaction",
                    "emphasis",
                    "numeric_emphasis",
                    "warning",
                    "tease"
                  ]
                },
                "style_token": { "type": "string", "minLength": 1 },
                "speaker_id": { "type": "string" },
                "safe_anchor": {
                  "type": "string",
                  "enum": ["top", "upper_third", "center", "lower_third", "bottom", "auto"]
                },
                "source_word_ids": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/baseOperation" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type", "track", "timeline", "rationale", "action"],
              "properties": {
                "id": true,
                "type": { "const": "audio_treatment" },
                "track": true,
                "timeline": true,
                "rationale": true,
                "enabled": true,
                "fallback": true,
                "extensions": true,
                "action": {
                  "type": "string",
                  "enum": ["gain", "fade_in", "fade_out", "crossfade", "duck", "denoise", "dereverb", "room_tone", "loudness_normalize"]
                },
                "value": { "type": "number" },
                "unit": {
                  "type": "string",
                  "enum": ["db", "seconds", "lufs", "ratio", "normalized"]
                },
                "asset_id": { "type": "string" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/baseOperation" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type", "track", "timeline", "rationale", "transition_kind", "duration_seconds"],
              "properties": {
                "id": true,
                "type": { "const": "transition" },
                "track": true,
                "timeline": true,
                "rationale": true,
                "enabled": true,
                "fallback": true,
                "extensions": true,
                "transition_kind": {
                  "type": "string",
                  "enum": ["cut", "cross_dissolve", "dip_to_black", "audio_crossfade", "semantic_token"]
                },
                "duration_seconds": {
                  "$ref": "#/$defs/seconds"
                },
                "style_token": { "type": "string" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/baseOperation" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type", "track", "timeline", "rationale", "graphic_kind", "style_token"],
              "properties": {
                "id": true,
                "type": { "const": "graphic" },
                "track": true,
                "timeline": true,
                "rationale": true,
                "enabled": true,
                "fallback": true,
                "extensions": true,
                "graphic_kind": {
                  "type": "string",
                  "enum": ["lower_third", "title", "chart", "map", "callout", "overlay", "generated_asset_request"]
                },
                "style_token": { "type": "string", "minLength": 1 },
                "text": { "type": "string" },
                "data": {
                  "type": "object",
                  "additionalProperties": true
                },
                "asset_id": { "type": "string" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/baseOperation" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type", "track", "timeline", "rationale", "effect_token"],
              "properties": {
                "id": true,
                "type": { "const": "effect" },
                "track": true,
                "timeline": true,
                "rationale": true,
                "enabled": true,
                "fallback": true,
                "extensions": true,
                "effect_token": { "type": "string", "minLength": 1 },
                "parameters": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          ]
        }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planner", "inputs"],
      "properties": {
        "planner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "model": { "type": "string" },
            "prompt_or_policy_hash": { "type": "string" }
          }
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "id", "fingerprint"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["project_contract", "asset_manifest", "production_graph", "human_instruction", "style_profile"]
              },
              "id": { "type": "string", "minLength": 1 },
              "fingerprint": { "type": "string", "minLength": 8 }
            }
          }
        },
        "seed": {
          "type": "integer"
        }
      }
    }
  }
}
