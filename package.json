{
  "name": "@waishnav/devspace",
  "version": "1.1.0",
  "description": "Expose a secure local coding workspace through an MCP server.",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22.19 <27"
  },
  "bin": {
    "devspace": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "agents",
    "scripts",
    "skills",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "clean:all": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && npm run build:app && tsc -p tsconfig.build.json",
    "build:app": "node scripts/build-app.mjs",
    "browser:install:chrome-for-testing": "node scripts/install-chrome-for-testing.mjs",
    "dev": "node scripts/dev-server.mjs",
    "ec2:prepare": "bash scripts/ec2-gag-bootstrap.sh prepare",
    "ec2:verify": "bash scripts/ec2-gag-bootstrap.sh verify",
    "ec2:doctor": "bash scripts/ec2-gag-doctor.sh",
    "ec2:env": "bash scripts/ec2-gag-bootstrap.sh print-env",
    "ec2:configure": "node scripts/ec2-gag-configure.mjs",
    "ec2:service:install": "bash scripts/ec2-gag-service.sh install",
    "ec2:service:verify": "bash scripts/ec2-gag-service.sh verify",
    "ec2:service:disable": "bash scripts/ec2-gag-service.sh disable",
    "ec2:e2e": "node scripts/ec2-gag-e2e.mjs",
    "runner:doctor": "bash scripts/linux-runner-bootstrap.sh doctor",
    "runner:prepare": "bash scripts/linux-runner-bootstrap.sh prepare",
    "runner:verify": "bash scripts/linux-runner-bootstrap.sh verify",
    "runner:env": "bash scripts/linux-runner-bootstrap.sh print-env",
    "runner:configure": "node scripts/linux-runner-configure.mjs",
    "runner:service:install": "bash scripts/linux-runner-service.sh install",
    "runner:service:verify": "bash scripts/linux-runner-service.sh verify",
    "runner:service:disable": "bash scripts/linux-runner-service.sh disable",
    "runner:cloudflare:doctor": "bash scripts/cloudflare-tunnel-service.sh doctor",
    "runner:cloudflare:install": "bash scripts/cloudflare-tunnel-service.sh install",
    "runner:cloudflare:verify": "bash scripts/cloudflare-tunnel-service.sh verify",
    "runner:cloudflare:disable": "bash scripts/cloudflare-tunnel-service.sh disable",
    "runner:github:install": "bash scripts/github-self-hosted-runner.sh install",
    "runner:github:verify": "bash scripts/github-self-hosted-runner.sh verify",
    "runtime:watchdog:install": "bash scripts/runtime-watchdog-service.sh install",
    "runtime:watchdog:verify": "bash scripts/runtime-watchdog-service.sh verify",
    "runtime:watchdog:disable": "bash scripts/runtime-watchdog-service.sh disable",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "start": "node dist/cli.js serve",
    "test": "tsx src/ec2-control.test.ts && tsx src/no-codex.test.ts && tsx src/google-ai-key-pool.test.ts && tsx src/config.test.ts && tsx src/chatgpt-model.test.ts && tsx src/chatgpt-task.test.ts && tsx src/browser-target-lifecycle.test.ts && tsx src/model-pricing.test.ts && tsx src/japanese-writing-kernel.test.ts && tsx src/gex-chat-runtime-store.test.ts && tsx src/shell-environment.test.ts && tsx src/runtime-operations.test.ts && tsx src/usage-meter.test.ts && tsx src/chat-progress.test.ts && tsx src/png-chroma-key.test.ts && tsx src/job-store.test.ts && tsx src/job-runner.test.ts && tsx src/computer-use.test.ts && tsx src/browser-computer.test.ts && tsx src/browser-task-loop.test.ts && tsx src/pi-tools.test.ts && tsx src/skill-matcher.test.ts && tsx src/compound-tools.test.ts && tsx src/design-audit.test.ts && tsx src/register-v11-tools.test.ts && tsx src/ui/card-types.test.ts && tsx src/ui/patch-display.test.ts && tsx src/apply-patch.test.ts && tsx src/process-platform.test.ts && tsx src/process-sessions.test.ts && tsx src/local-agent-runtime.test.ts && tsx src/local-agent-adapters.test.ts && tsx src/local-agent-availability.test.ts && tsx src/local-agent-profiles.test.ts && tsx src/local-agent-targets.test.ts && tsx src/local-agent-store.test.ts && tsx src/roots.test.ts && tsx src/skills.test.ts && tsx src/workspaces.test.ts && tsx src/review-checkpoints.test.ts && tsx src/oauth-store.test.ts && tsx src/cli.test.ts",
    "test:runtime": "tsx src/shell-environment.test.ts && tsx src/runtime-operations.test.ts && tsx src/usage-meter.test.ts",
    "test:naobrain": "tsx src/naobrain-today-store.test.ts && tsx src/naobrain-quiz-store.test.ts",
    "naobrain:configure": "bash scripts/configure-naobrain-today.sh",
    "test:browser-computer": "tsx src/browser-computer.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@anthropic-ai/claude-agent-sdk": "^0.3.200",
    "@clack/prompts": "^1.5.1",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.142.5",
    "@opencode-ai/sdk": "^1.17.13",
    "@pierre/diffs": "^1.2.5",
    "better-sqlite3": "^12.10.0",
    "diff": "^8.0.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "semver": "^7.8.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "overrides": {
    "protobufjs": "7.6.4",
    "ws": "8.21.0",
    "undici": "8.5.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
